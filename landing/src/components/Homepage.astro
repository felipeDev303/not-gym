---
import { Image } from 'astro:assets';

// CORRECCIÓN: Importamos el componente Image de Astro para optimización y SEO

// El objeto de traducciones 't' se mantiene igual
const t = {
  heroTitle: 'Tu Ciudad es tu Gimnasio.',
  heroDesc: 'Estamos creando una comunidad para mapear cada parque con barras, pista de trote y espacio público para entrenar.',
  heroFree: 'Totalmente gratis, para siempre.',
  familiarTitle: '¿Te suena familiar?',
  familiarProblems: [
    'Quiero entrenar, pero no quiero pagar.',
    'La misma rutina en el mismo lugar, día tras día.',
    'No saber dónde encontrar buenos lugares públicos para entrenar.',
  ],
  simple: 'NotGym.org lo hace simple.',
  steps: [
    {
      title: 'EXPLORA',
      icon: 'explore',
      colorBg: 'bg-green-100',
      colorIcon: 'text-green-600',
      desc: 'Abre el mapa y encuentra al instante lugares cerca de ti filtrados por el tipo de ejercicio que quieres hacer.',
    },
    {
      title: 'ENTRENA',
      icon: 'fitness_center',
      colorBg: 'bg-orange-100',
      colorIcon: 'text-orange-600',
      desc: 'Descubre rutinas creadas por la comunidad o simplemente disfruta del espacio y haz la tuya.',
    },
    {
      title: 'COMPARTE',
      icon: 'favorite',
      colorBg: 'bg-pink-100',
      colorIcon: 'text-pink-600',
      desc: '¿Encontraste un nuevo lugar increíble? Añádelo al mapa en segundos y ayuda a que la comunidad crezca.',
    },
  ],
  visionTitle: 'Más que una App, un Movimiento',
  visionDesc:
    'Creemos que la salud y el bienestar deben ser accesibles para todos, no un lujo. NotGym.org es una iniciativa sin fines de lucro para re-apropiarnos de los espacios públicos, fomentar la vida sana y conectar a personas que comparten la pasión por el deporte. Tu ciudad tiene el potencial, nosotros solo te damos el mapa.',
  ctaTitle: '¿Listo para transformar tu ciudad en tu gimnasio?',
  ctaDesc: 'Deja tu correo y sé uno de los primeros en recibir la invitación. Juntos, vamos a construir el mapa de fitness más grande del mundo.',
};
---

<main id="main-content" class="space-y-24 md:space-y-32">
  <!-- Hero -->
  <section class="relative min-h-[70vh] flex items-center justify-center bg-gray-900 text-white">
    <div class="relative z-10 w-full max-w-4xl mx-auto text-center px-4 py-16 md:py-24">
      <h1 class="text-3xl xs:text-4xl sm:text-5xl md:text-7xl font-extrabold mb-6 leading-tight">
        {t.heroTitle} <br />
        <span class="text-accent">Descúbrela.</span>
      </h1>
      <p class="text-base xs:text-lg sm:text-xl md:text-2xl mb-8 text-gray-200 max-w-2xl mx-auto">
        {t.heroDesc} <br />
        <span class="font-medium text-accent">{t.heroFree}</span>
      </p>
      <div class="max-w-md mx-auto">
        <div class="ml-embedded" data-form="O9Hyzx"></div>
      </div>
    </div>
  </section>

  <!-- Problemas -->
  <section id="about" class="bg-gray-50 py-14 md:py-20">
    <div class="container mx-auto px-4 max-w-5xl">
      <h2 class="text-2xl xs:text-3xl sm:text-4xl md:text-5xl font-bold text-center text-gray-900 mb-10 md:mb-12">
        {t.familiarTitle}
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8 md:gap-10">
        {t.familiarProblems.map((problem, i) => {
          const icons = ['money_off', 'sentiment_dissatisfied', 'help'];
          const colors = ['bg-red-100 text-red-600', 'bg-blue-100 text-blue-600', 'bg-yellow-100 text-yellow-600'];
          return (
            <article class="text-center p-6 flex flex-col items-center">
              <div class={`w-14 h-14 sm:w-16 sm:h-16 mb-4 rounded-full flex items-center justify-center ${colors[i].split(' ')[0]}`}>
                <span class={`material-icons text-2xl sm:text-3xl ${colors[i].split(' ')[1]}`} aria-hidden="true">
                  {icons[i]}
                </span>
              </div>
              <h3 class="text-base sm:text-lg md:text-xl font-bold text-gray-900">{problem}</h3>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Solución -->
  <section id="features" class="bg-white py-14 md:py-20">
    <div class="container mx-auto px-4 max-w-5xl">
      <h2 class="text-2xl xs:text-3xl sm:text-4xl md:text-5xl font-bold text-center text-gray-900 mb-10 md:mb-12">{t.simple}</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8 md:gap-10">
        {t.steps.map(({ title, icon, colorBg, colorIcon, desc }, i) => (
          <article class="text-center p-6 flex flex-col items-center">
            <div class={`${colorBg} w-14 h-14 sm:w-16 sm:h-16 mb-4 rounded-full flex items-center justify-center`}>
              <span class={`material-icons text-2xl sm:text-3xl ${colorIcon}`} aria-hidden="true">{icon}</span>
            </div>
            <h3 class="text-base sm:text-lg md:text-xl font-bold text-gray-900 mb-3">{title}</h3>
            <p class="text-gray-600 text-sm sm:text-base">{desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Visión -->
  <section class="bg-gray-900 text-white py-14 md:py-20">
    <div class="container mx-auto px-4 max-w-4xl">
      <h2 class="text-2xl xs:text-3xl sm:text-4xl md:text-5xl font-bold text-center mb-6 md:mb-8">{t.visionTitle}</h2>
      <p class="text-base sm:text-lg md:text-2xl leading-relaxed text-gray-300 text-center">{t.visionDesc}</p>
    </div>
  </section>

  <!-- CTA Final -->
  <section id="contact" class="bg-gray-50 py-14 md:py-20">
    <div class="container mx-auto px-4 max-w-3xl text-center">
      <h2 class="text-2xl xs:text-3xl sm:text-4xl md:text-5xl font-bold text-gray-900 mb-4 md:mb-6">{t.ctaTitle}</h2>
      <p class="text-base sm:text-lg md:text-xl text-gray-600 mb-6 md:mb-8">{t.ctaDesc}</p>
      <div class="max-w-md mx-auto">
        <div class="ml-embedded" data-form="O9Hyzx"></div>
      </div>
    </div>
  </section>
</main>