---
import FaviconIcon from './FaviconIcon.astro';
const socialLinks = [
  { href: "https://instagram.com/notgymorg", icon: "camera_alt", name: "Instagram" },
  { href: "https://facebook.com/notgym.org", icon: "facebook", name: "Facebook" },
  { href: "https://tiktok.com/@notgym.org", icon: "music_note", name: "TikTok" },
  { href: "https://linkedin.com/company/notgymorg", icon: "work", name: "LinkedIn" },
  { href: "https://x.com/NotGymOrg", icon: "chat", name: "X (Twitter)" },
  { href: "https://youtube.com/@NotGymOrg", icon: "play_circle", name: "YouTube" },
  { href: "mailto:notgym.org@gmail.com", icon: "email", name: "Email" },
];
---
<footer class="bg-gray-900 text-white py-12">
    <div class="container mx-auto px-4">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <div>
                <div class="flex items-center space-x-2 mb-4">
                    <FaviconIcon className="w-16 h-16" />
                </div>
                <p class="roboto-regular text-gray-400">
                    Transformando tu ciudad en tu gimnasio personal. Descubre espacios de entrenamiento gratuitos cerca de ti.
                </p>
            </div>
            <div>
                <h3 class="roboto-bold mb-4">Enlaces</h3>
                <ul class="space-y-2 text-gray-400">
                    <li><a href="#about" class="roboto-medium transition-colors hover:text-accent">Acerca de</a></li>
                    <li><a href="#features" class="roboto-medium transition-colors hover:text-accent">Características</a></li>
                    <li><a href="#contact" class="roboto-medium transition-colors hover:text-accent">Contacto</a></li>
                </ul>
            </div>
            <div>
                <h3 class="roboto-bold mb-4">Síguenos</h3>
                <div class="flex flex-row flex-wrap gap-4 text-gray-400">
                  {socialLinks.map(link => (
                      <a 
                          href={link.href} 
                          target={link.name === 'Email' ? '_self' : '_blank'} 
                          rel="noopener noreferrer" 
                          class="roboto-medium transition-colors flex items-center hover:text-accent"
                          aria-label={link.name}
                      >
                          <span class="material-icons text-2xl" aria-hidden="true">{link.icon}</span>
                      </a>
                  ))}
                </div>
            </div>
        </div>
        <div class="border-t border-gray-800 mt-8 pt-8 text-center text-gray-400">
            <p class="roboto-light">© {new Date().getFullYear()} NotGym.org. Todos los derechos reservados.</p>
        </div>
    </div>
</footer>