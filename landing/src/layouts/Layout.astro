---
const title = "Not Gym";
const description = "Transforma tu ciudad en tu gimnasio personal. Descubre espacios de entrenamiento gratuitos cerca de ti.";
const mailerliteScript = `
	(function(w,d,e,u,f,l,n){w[f]=w[f]||function(){(w[f].q=w[f].q||[])
	.push(arguments);},l=d.createElement(e),l.async=1,l.src=u,
	n=d.getElementsByTagName(e)[0],n.parentNode.insertBefore(l,n);})
	(window,document,'script','https://assets.mailerlite.com/js/universal.js','ml');
	ml('account', '1608433');
`;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />

		<!-- SEO y Meta Tags -->
		<title>{title}</title>
		<meta name="description" content={description} />
		
		<!-- CORRECCIÓN: Añadidos Meta Tags para redes sociales (Open Graph / Twitter) -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL('/social-image.jpg', Astro.url)} /> <!-- Asegúrate de tener una imagen social-image.jpg en tu carpeta /public -->
		<meta property="og:url" content={Astro.url} />
		<meta property="og:type" content="website" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={new URL('/social-image.jpg', Astro.url)} />

		<!-- Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;700;900&display=swap" rel="stylesheet">
		<link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">

		<!-- MailerLite Universal -->
		<script set:html={mailerliteScript}></script>
	</head>
	<body class="bg-white text-gray-900 min-h-screen">
		<!-- CORRECCIÓN: Se eliminó el <header> de aquí. El slot es el único hijo directo del body. -->
		<slot />
	</body>
</html>
<style is:global>
	/* ... Tu CSS global se mantiene igual ... */
	:root {
		--accent: 25, 118, 210;
		--accent-light: 144, 202, 249;
		--accent-dark: 21, 101, 192;
		--primary: #1976d2;
		--primary-dark: #1565c0;
		--primary-light: #90caf9;
		--accent-gradient: linear-gradient(
			45deg,
			rgb(var(--accent)),
			rgb(var(--accent-light)) 30%,
			white 60%
		);
	}
	html {
		font-family: 'Roboto', system-ui, sans-serif;
		background: #fff;
		scroll-behavior: smooth; /* CORRECCIÓN: Añadido para que los enlaces de ancla (#) se desplacen suavemente */
	}
	body {
		transition: background 0.3s;
		background: #fff;
	}
	body, html {
		min-height: 100vh;
	}
	code {
		font-family:
			Menlo,
			Monaco,
			Lucida Console,
			Liberation Mono,
			DejaVu Sans Mono,
			Bitstream Vera Sans Mono,
			Courier New,
			monospace;
	}
	.text-primary {
		color: var(--primary);
	}
	.bg-primary {
		background-color: var(--primary);
	}
	.bg-primary-dark {
		background-color: var(--primary-dark);
	}
</style>