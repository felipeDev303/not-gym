---
import Layout from '../../layouts/Layout.astro'
import { createSupabaseServerClient } from '../../lib/supabase'

const session = Astro.locals.session
if (!session) return Astro.redirect('/login?redirect=/app/submit')

const supabase = createSupabaseServerClient(Astro.cookies)
const { data: categories } = await supabase
  .from('spot_categories')
  .select('id, slug, name, icon')
  .order('name')

const lat = Astro.url.searchParams.get('lat') ?? ''
const lng = Astro.url.searchParams.get('lng') ?? ''
---

<Layout title="Agregar spot">
  <main class="submit-page">
    <div class="container">
      <a href="/app/map" class="back-link">← Volver al mapa</a>
      <h1>Agregar un spot</h1>
      <p class="hint">Los spots nuevos quedan pendientes hasta ser verificados por un admin.</p>

      <div id="status-msg" class="status-msg" style="display:none"></div>

      <form id="spot-form">
        <div class="field">
          <label for="name">Nombre *</label>
          <input id="name" name="name" type="text" required placeholder="Ej: Parque Central Calistenia" />
        </div>

        <div class="field">
          <label for="category_id">Categoría *</label>
          <select id="category_id" name="category_id" required>
            <option value="">Seleccioná una categoría</option>
            {categories?.map(c => (
              <option value={c.id}>{c.icon} {c.name}</option>
            ))}
          </select>
        </div>

        <div class="field-row">
          <div class="field">
            <label for="latitude">Latitud *</label>
            <input id="latitude" name="latitude" type="number" step="any" required value={lat} />
          </div>
          <div class="field">
            <label for="longitude">Longitud *</label>
            <input id="longitude" name="longitude" type="number" step="any" required value={lng} />
          </div>
        </div>

        <div class="field">
          <label for="address">Dirección</label>
          <input id="address" name="address" type="text" placeholder="Ej: Av. del Libertador 1000" />
        </div>

        <div class="field">
          <label for="description">Descripción</label>
          <textarea id="description" name="description" rows="3" placeholder="Describí el spot: equipamiento, estado, acceso..."></textarea>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn btn-primary">Enviar spot</button>
          <a href="/app/map" class="btn btn-outline">Cancelar</a>
        </div>
      </form>
    </div>
  </main>
</Layout>

<script>
  const form = document.getElementById('spot-form') as HTMLFormElement
  const statusMsg = document.getElementById('status-msg')!

  form.addEventListener('submit', async (e) => {
    e.preventDefault()
    const data = Object.fromEntries(new FormData(form))

    const res = await fetch('/api/spots', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        name: data.name,
        description: data.description || null,
        category_id: parseInt(data.category_id as string),
        latitude: parseFloat(data.latitude as string),
        longitude: parseFloat(data.longitude as string),
        address: data.address || null,
      }),
    })

    if (res.ok) {
      const spot = await res.json()
      statusMsg.className = 'status-msg success'
      statusMsg.textContent = '✓ Spot enviado. Quedará visible una vez verificado.'
      statusMsg.style.display = 'block'
      form.reset()
      setTimeout(() => window.location.href = `/app/spots/${spot.id}`, 1500)
    } else {
      const { error } = await res.json()
      statusMsg.className = 'status-msg error'
      statusMsg.textContent = `Error: ${error}`
      statusMsg.style.display = 'block'
    }
  })
</script>

<style>
  .submit-page { padding: 2rem 1.5rem; }
  .container { max-width: 560px; margin: 0 auto; }
  .back-link { color: var(--muted); font-size: 0.9rem; }
  .back-link:hover { color: var(--text); }
  h1 { font-size: 1.5rem; font-weight: 700; margin: 1.25rem 0 0.25rem; }
  .hint { color: var(--muted); font-size: 0.85rem; margin-bottom: 1.75rem; }

  .field { display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 1.1rem; }
  .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; }
  label { font-size: 0.85rem; color: var(--muted); }

  input, select, textarea {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--text);
    font-size: 0.95rem;
    padding: 0.6rem 0.85rem;
    outline: none;
    width: 100%;
    font-family: inherit;
    transition: border-color 0.15s;
  }
  input:focus, select:focus, textarea:focus { border-color: var(--accent); }
  select option { background: var(--surface); }

  .form-actions { display: flex; gap: 0.75rem; margin-top: 0.5rem; }

  .btn {
    display: inline-block;
    padding: 0.65rem 1.25rem;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    border: none;
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .btn:hover { opacity: 0.85; text-decoration: none; }
  .btn-primary { background: var(--accent); color: #0f0f0f; }
  .btn-outline { background: transparent; border: 1px solid var(--border); color: var(--text); }

  .status-msg {
    border-radius: 8px;
    padding: 0.65rem 0.9rem;
    font-size: 0.875rem;
    margin-bottom: 1.25rem;
  }
  .status-msg.success { background: #052e16; border: 1px solid #166534; color: #86efac; }
  .status-msg.error { background: #3b0000; border: 1px solid #7f1d1d; color: #fca5a5; }
</style>
